# Ignore Visual Studio temporary files, build results, and
# files generated by popular Visual Studio add-ons.
.vs/
*.VC.db
*.VC.opendb
*.suo
*.user
*.userosscache
*.sln.docstates

# Ignore build results
Binaries/
DerivedDataCache/
Intermediate/
Saved/
Build/

# Ignore working files
*.log
*.tlog
*.obj
*.pdb
*.exe
*.dll
*.app
*.dylib
*.icns
*.ipa
*.lib
*.so
*.sdf
*.opensdf
*.cache
*.db
*.suo
*.tmp
*.csproj.user

# Ignore OS generated files
.DS_Store
Thumbs.db

# Ignore Crash Reports
CrashReportClient/

# Ignore config files specific to users
*.local
*.orig

# Ignore Unreal Engine Launcher backup files
Backup/